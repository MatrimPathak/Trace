rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Screenshots: owner can read and write
    match /screenshots/{userId}/{taskId}/{file} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024   // 10 MB limit
        && request.resource.contentType.matches('image/.*');
    }

    // Artifacts: owner can read and write
    match /artifacts/{userId}/{taskId}/{file} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 25 * 1024 * 1024;  // 25 MB limit
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
